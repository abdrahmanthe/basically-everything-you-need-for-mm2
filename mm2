-- Helper for buttons
local function createButton(name,posY)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.8,0,0,30)
	btn.Position = UDim2.new(0.1,0,0,posY)
	btn.Text = name
	btn.BackgroundColor3 = Color3.fromRGB(170,0,0)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Parent = frame
	Instance.new("UICorner",btn).CornerRadius = UDim.new(0,6)
	return btn
end

-- Buttons
local jumpBtn = createButton("Infinite Jump: OFF", 90)
local increaseSpeedBtn = createButton("Increase Speed (+10)", 130)
local decreaseSpeedBtn = createButton("Decrease Speed (-10)", 170)
local increaseJumpBtn = createButton("Increase Jump (+10)", 210)
local decreaseJumpBtn = createButton("Decrease Jump (-10)", 250)
