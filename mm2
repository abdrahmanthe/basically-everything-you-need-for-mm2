teleportTitle.Position = UDim2.new(0.1,0,0,330)
teleportTitle.BackgroundTransparency = 1
teleportTitle.Text = "Teleport to Player:"
teleportTitle.TextColor3 = Color3.new(1,1,1)
teleportTitle.Font = Enum.Font.Gotham
teleportTitle.TextSize = 14
teleportTitle.Parent = frame

-- Search box
local searchBox = Instance.new("TextBox")
searchBox.Size = UDim2.new(0.8,0,0,25)
searchBox.Position = UDim2.new(0.1,0,0,350)
searchBox.PlaceholderText = "Search Player..."
searchBox.Text = ""
searchBox.ClearTextOnFocus = false
searchBox.TextColor3 = Color3.new(1,1,1)
