-- Save & Load
local function saveSettings()
	pcall(function()
		settingsStore:SetAsync(player.UserId, {speed=walkSpeed, jump=jumpPower, infiniteJump=infiniteJumpEnabled})
	end)
end

local function loadSettings()
	local success, data = pcall(function()
		return settingsStore:GetAsync(player.UserId)
	end)
	if success and data then
		walkSpeed = data.speed or DEFAULT_SPEED
		jumpPower = data.jump or DEFAULT_JUMP
		infiniteJumpEnabled = data.infiniteJump or DEFAULT_INFINITE_JUMP
	end
	humanoid.WalkSpeed = walkSpeed
	humanoid.JumpPower = jumpPower
	speedLabel.Text = "Speed: "..walkSpeed
	jumpLabel.Text = "Jump Power: "..jumpPower
	jumpBtn.Text = "Infinite Jump: "..(infiniteJumpEnabled and "ON" or "OFF")
	jumpBtn.BackgroundColor3 = infiniteJumpEnabled and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
end
loadSettings()

-- Update Player List
local function updatePlayerList()
	playerListFrame:ClearAllChildren()
	local playerTable = {}
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= player and (searchText == "" or p.Name:lower():find(searchText:lower())) then
			table.insert(playerTable,p)
		end
	end
	table.sort(playerTable,function(a,b) return a.Name:lower() < b.Name:lower() end)
	for _, p in ipairs(playerTable) do
		local btn = Instance.new("TextButton")
		btn.Size = UDim2.new(1,0,0,25)
		btn.Text = p.Name
		btn.BackgroundColor3 = Color3.fromRGB(60,60,60)
		btn.TextColor3 = Color3.new(1,1,1)
		btn.Parent = playerListFrame
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)
		btn.MouseButton1Click:Connect(function()
			if selectedPlayerBtn then
				selectedPlayerBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
			end
			selectedPlayerBtn = btn
			btn.BackgroundColor3 = Color3.fromRGB(0,170,0)
			local char = p.Character
			if char and char:FindFirstChild("HumanoidRootPart") and rootPart then
				rootPart.CFrame = char.HumanoidRootPart.CFrame + Vector3.new(0,3,0)
			end
		end)
	end
	task.wait() -- ensure layout updated
	playerListFrame.CanvasSize = UDim2.new(0,0,listLayout.AbsoluteContentSize.Y,0)
end

searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	searchText = searchBox.Text
	updatePlayerList()
end)
Players.PlayerAdded:Connect(updatePlayerList)
Players.PlayerRemoving:Connect(updatePlayerList)
updatePlayerList()

-- Button actions with Tween feedback
local function tweenButtonColor(btn,color)
	local tween = TweenService:Create(btn,TweenInfo.new(0.2),{BackgroundColor3=color})
	tween:Play()
end

jumpBtn.MouseButton1Click:Connect(function()
	infiniteJumpEnabled = not infiniteJumpEnabled
	jumpBtn.Text = "Infinite Jump: "..(infiniteJumpEnabled and "ON" or "OFF")
	jumpBtn.BackgroundColor3 = infiniteJumpEnabled and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
	saveSettings()
end)
UIS.JumpRequest:Connect(function()
	if infiniteJumpEnabled and humanoid then
		humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
	end
end)

increaseSpeedBtn.MouseButton1Click:Connect(function()
	walkSpeed = walkSpeed + 10
	if humanoid then humanoid.WalkSpeed = walkSpeed end
	speedLabel.Text = "Speed: "..walkSpeed
	tweenButtonColor(increaseSpeedBtn, Color3.fromRGB(0,170,0))
	task.wait(0.2)
	tweenButtonColor(increaseSpeedBtn, Color3.fromRGB(170,0,0))
	saveSettings()
end)

decreaseSpeedBtn.MouseButton1Click:Connect(function()
	walkSpeed = math.max(16, walkSpeed - 10)
	if humanoid then humanoid.WalkSpeed = walkSpeed end
	speedLabel.Text = "Speed: "..walkSpeed
	tweenButtonColor(decreaseSpeedBtn, Color3.fromRGB(0,170,0))
	task.wait(0.2)
	tweenButtonColor(decreaseSpeedBtn, Color3.fromRGB(170,0,0))
	saveSettings()
end)

increaseJumpBtn.MouseButton1Click:Connect(function()
	jumpPower = jumpPower + 10
	if humanoid then humanoid.JumpPower = jumpPower end
	jumpLabel.Text = "Jump Power: "..jumpPower
	tweenButtonColor(increaseJumpBtn, Color3.fromRGB(0,170,0))
	task.wait(0.2)
	tweenButtonColor(increaseJumpBtn, Color3.fromRGB(170,0,0))
	saveSettings()
end)

decreaseJumpBtn.MouseButton1Click:Connect(function()
	jumpPower = math.max(50, jumpPower - 10)
	if humanoid then humanoid.JumpPower = jumpPower end
	jumpLabel.Text = "Jump Power: "..jumpPower
	tweenButtonColor(decreaseJumpBtn, Color3.fromRGB(0,170,0))
	task.wait(0.2)
	tweenButtonColor(decreaseJumpBtn, Color3.fromRGB(170,0,0))
	saveSettings()
end)

resetBtn.MouseButton1Click:Connect(function()
	infiniteJumpEnabled = false
	jumpBtn.Text = "Infinite Jump: OFF"
	jumpBtn.BackgroundColor3 = Color3.fromRGB(170,0,0)
	walkSpeed = DEFAULT_SPEED
	if humanoid then humanoid.WalkSpeed = walkSpeed end
	speedLabel.Text = "Speed: "..walkSpeed
	jumpPower = DEFAULT_JUMP
	if humanoid then humanoid.JumpPower = jumpPower end
	jumpLabel.Text = "Jump Power: "..jumpPower
	if selectedPlayerBtn then
		selectedPlayerBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
		selectedPlayerBtn = nil
	end
	tweenButtonColor(increaseSpeedBtn, Color3.fromRGB(170,0,0))
	tweenButtonColor(decreaseSpeedBtn, Color3.fromRGB(170,0,0))
	tweenButtonColor(increaseJumpBtn, Color3.fromRGB(170,0,0))
	tweenButtonColor(decreaseJumpBtn, Color3.fromRGB(170,0,0))
	saveSettings()
end)

